<Window x:Class="InsuranceBrokerApp_UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Insurance Broker"
        Height="650"
        Width="900"
        MinHeight="350"
        MinWidth="500"
        Background="#E6E6FA">

    <Window.Resources>
        <!-- Stil butoane -->
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Stil titluri -->
        <Style TargetType="TextBlock" x:Key="Titlu">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2F4F4F"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- MENIU -->
        <Menu x:Name="mainMenu" Grid.Row="0" Background="#4B6CB7" Foreground="White">
            <MenuItem Header="Navigare">
                <MenuItem Header="Clienti" Click="MenuClienti_Click"/>
                <MenuItem Header="Polite" Click="MenuPolite_Click"/>
                <MenuItem Header="Home" Click="MenuHome_Click"/>
            </MenuItem>

            <MenuItem Header="Aplicatie">
                <MenuItem Header="Iesire" Click="MenuIesire_Click"/>
            </MenuItem>
        </Menu>

        <!-- CONTINUT -->
        <Grid Grid.Row="1">

            <!-- HOME -->
            <StackPanel x:Name="panelHome"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">

                <TextBlock Text="Meniu Principal"
                           Style="{StaticResource Titlu}"
                           Margin="0,0,0,30"/>

                <Button Content="Administrare Clienti"
                        Click="MenuClienti_Click"
                        Width="220"
                        Height="50"
                        Background="#6A5ACD"
                        Foreground="White"/>

                <Button Content="Administrare Polite"
                        Click="MenuPolite_Click"
                        Width="220"
                        Height="50"
                        Background="#20B2AA"
                        Foreground="White"/>
            </StackPanel>

            <!-- CLIENTI -->
            <Grid x:Name="panelClienti" Visibility="Collapsed">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <!-- FORM -->
                <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="15" Margin="10">
                    <StackPanel>

                        <Button Content="⬅ Inapoi"
                                Click="MenuHome_Click"
                                Width="100"
                                Background="#D3D3D3"/>

                        <TextBlock Text="Administrare Clienti"
                                   Style="{StaticResource Titlu}"
                                   Margin="0,10"/>

                        <TextBlock Text="Nume"/>
                        <TextBox x:Name="txtNume"/>

                        <TextBlock Text="Telefon"/>
                        <TextBox x:Name="txtTelefon"/>

                        <TextBlock Text="CNP"/>
                        <TextBox x:Name="txtCNP"/>

                       

                        <StackPanel Orientation="Horizontal" Margin="0,10">
                            <Button Content="Adauga"
                                    Click="Executa_Click"
                                    Background="#6A5ACD"
                                    Foreground="White"/>

                            <Button Content="Modifica"
                                    Click="Modifica_Click"
                                    Background="#20B2AA"
                                    Foreground="White"/>
                        </StackPanel>

                        <TextBlock x:Name="txtRezultat"
                                   Foreground="DarkGreen"
                                   FontWeight="Bold"/>

                    </StackPanel>
                </Border>

                <!-- LISTA -->
                <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="15" Margin="10">
                    <StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="txtCauta" Width="200"/>
                            <Button Content="Cauta" Click="Cauta_Click"/>
                            <Button Content="Reset" Click="Reset_Click"/>
                        </StackPanel>

                        <TextBlock Text="Lista clienti"
                                   FontWeight="Bold"
                                   Margin="0,10,0,5"/>

                        <ListBox x:Name="lstClienti"
                                 SelectionChanged="lstClienti_SelectionChanged"
                                 Height="350"/>

                    </StackPanel>
                </Border>

            </Grid>

            <!-- POLITE -->
            <Border x:Name="panelPolite"
                    Visibility="Collapsed"
                    Background="White"
                    CornerRadius="10"
                    Padding="15"
                    Margin="10">

                <StackPanel>

                    <Button Content="⬅ Inapoi"
                            Click="MenuHome_Click"
                            Width="100"
                            Background="#D3D3D3"/>

                    <TextBlock Text="Administrare Polite"
                               Style="{StaticResource Titlu}"
                               Margin="0,10"/>

                    <TextBlock Text="Selecteaza client"/>
                    <ComboBox x:Name="cmbClienti"
          IsEditable="True"
          IsTextSearchEnabled="True"
          StaysOpenOnEdit="True"
          DisplayMemberPath="Nume"
          SelectedValuePath="Id"
          SelectionChanged="cmbClienti_SelectionChanged"/>

                    <TextBlock Text="Tip polita" Margin="0,10,0,0"/>
                    <StackPanel>
                        <RadioButton x:Name="rbRCA_P" Content="RCA"/>
                        <RadioButton x:Name="rbCASCO_P" Content="CASCO"/>
                        <RadioButton x:Name="rbLocuinta_P" Content="Locuinta"/>
                        <RadioButton x:Name="rbViata_P" Content="Viata"/>
                    </StackPanel>

                    <TextBlock Text="Optiuni suplimentare" Margin="0,10,0,0"/>
                    <StackPanel>
                        <CheckBox x:Name="chkUrgenta_P" Content="Urgenta"/>
                        <CheckBox x:Name="chkSuport_P" Content="Suport 24/7"/>
                        <CheckBox x:Name="chkAsistenta_P" Content="Asistenta rutiera"/>
                    </StackPanel>
                    <TextBlock Text="Data inceput" Margin="0,10,0,0"/>
                    <DatePicker x:Name="dpDataStart"  SelectedDateChanged="DataChanged"/>

                    <TextBlock Text="Durata polita" Margin="0,10,0,0"/>

                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="rb1Luna" Content="1 luna" GroupName="Durata" Checked="DataChanged"/>
                        <RadioButton x:Name="rb6Luni" Content="6 luni" GroupName="Durata" Checked="DataChanged"/>
                        <RadioButton x:Name="rb12Luni" Content="12 luni" GroupName="Durata" Checked="DataChanged"/>
                    </StackPanel>

                    <TextBlock Text="Data expirare" Margin="0,10,0,0"/>
                    <TextBox x:Name="txtDataExpirare" IsReadOnly="True"/>

                    

                    <Button Content="Adauga polita"
                            Click="AdaugaPolita_Click"
                            Background="#20B2AA"
                            Foreground="White"
                            Margin="0,10"/>

                    <TextBlock Text="Polite client:" FontWeight="Bold"/>
                    <ListBox x:Name="lstPolite"/>

                </StackPanel>
            </Border>

        </Grid>

    </Grid>
</Window>