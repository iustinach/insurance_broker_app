<Window x:Class="InsuranceBrokerApp_UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clienti" Height="350" Width="500">

    <Grid Background="Lavender">
        <Border Padding="15">
            <StackPanel>

                <TextBlock Text="Informatii Client"
                           FontSize="22"
                           Foreground="DarkBlue"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                
                <TextBlock Text="Nume:"
                           Foreground="DarkBlue"
                           FontWeight="Bold"/>
                <TextBox x:Name="txtNume"
                         Margin="0,5,0,10"
                         Background="White"
                         Width="250"
                         HorizontalAlignment="Left"/>

                
                <TextBlock Text="Telefon:"
                           FontWeight="Bold"
                           Foreground="DarkBlue"/>
                <TextBox x:Name="txtTelefon"
                         Margin="0,5,0,10"
                         Background="White"
                         Width="250"
                         HorizontalAlignment="Left"/>

               
                <Button Content="Afiseaza"
                        Background="CornflowerBlue"
                        Foreground="White"
                        FontWeight="Bold"
                        Padding="6"
                        Width="120"
                        HorizontalAlignment="Left"
                        Click="Button_Click"/>

                
                <TextBlock x:Name="txtRezultat"
                           Margin="0,15,0,0"
                           FontWeight="Bold"
                           TextWrapping="Wrap"
                           Foreground="DarkGreen"
                           FontSize="14"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>